DJANGO_SECRET_KEY=change-me
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# Product service database: PostgreSQL
# Use 127.0.0.1 when running Django directly on your machine.
# Use host.docker.internal when running Django inside Docker.
PRODUCT_DB_NAME=
PRODUCT_DB_USER=
PRODUCT_DB_PASSWORD=
PRODUCT_DB_HOST=host.docker.internal
PRODUCT_DB_PORT=5432
PRODUCT_DB_ADMIN_USER=
PRODUCT_DB_ADMIN_PASSWORD=
PRODUCT_DB_ADMIN_HOST=127.0.0.1
PRODUCT_DB_ADMIN_PORT=5432

# Other services database: MySQL
MYSQL_DB_NAME=
MYSQL_DB_USER=
MYSQL_DB_PASSWORD=
MYSQL_DB_HOST=host.docker.internal
MYSQL_DB_PORT=3306
MYSQL_DB_ADMIN_USER=
MYSQL_DB_ADMIN_PASSWORD=
MYSQL_DB_ADMIN_HOST=127.0.0.1
MYSQL_DB_ADMIN_PORT=3306

# AI chatbot LLM provider keys
# For GitHub Models, create a GitHub personal access token with models:read.
GITHUB_TOKEN=
GITHUB_MODEL=openai/gpt-4o-mini
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
